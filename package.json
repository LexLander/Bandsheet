{
  "name": "bandsheet",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "audit:i18n": "npx --yes tsx scripts/i18n-bootstrap-audit.ts",
    "smoke:i18n": "vitest run tests/api/i18n.route.test.ts",
    "smoke:invite": "vitest run tests/public/invite.actions.test.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ci": "npm run lint && npm run test && npm run smoke:i18n && npm run smoke:invite && npm run audit:i18n && npm run test:coverage && npm run build"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
